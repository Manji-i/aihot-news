# ============================================================
# aihot-news 配置文件
# 复制此文件为 config.sh 并填入你的实际值：
#   cp config.sh.example config.sh
# ============================================================

# ---- 飞书/Lark 发送目标 ----
# 目标群聊的 chat_id（从飞书开发者后台或 lark-cli 获取）
CHAT_ID="oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# cron 使用你本机已登录的 lark-cli。请先确认 lark-cli 在 PATH 中可用，
# 并且目标机器人已加入 CHAT_ID 对应的群聊。

# ---- API 数据源 ----
API_BASE="https://aihot.virxact.com"

# ---- 发送控制 ----
# 每条飞书消息最多包含多少条新闻
MAX_PER_MESSAGE=3
# 每页拉取条数
PAGE_SIZE=50
# 回看窗口小时数：AI Hot 精选可能后补较早发布时间的条目，脚本会回看并用 ID 去重
LOOKBACK_HOURS=12
# 保留多少个已发送条目 ID 用于去重
MAX_SENT_IDS=1000

# ---- 路径（可留空，默认使用脚本所在目录） ----
# STATE_FILE="/path/to/state.json"
# POLL_LOG="/path/to/poll.log"
